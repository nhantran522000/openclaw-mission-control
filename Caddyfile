# Caddyfile for Mission Control Reverse Proxy
# =============================================
# This configuration sets up Caddy as a reverse proxy for the Mission Control application.
#
# For local development, this uses http://localhost (no HTTPS).
# For production, uncomment the production section and configure your domain.

# -----------------------------------------------------------------------------
# LOCAL DEVELOPMENT CONFIGURATION
# -----------------------------------------------------------------------------
# Uses http:// to disable automatic HTTPS for local development
http://localhost {
    # Reverse proxy to the mission-control service
    reverse_proxy mission-control:3000

    # Enable gzip compression for better performance
    encode gzip zstd

    # Basic security headers
    header {
        # Prevent clickjacking
        X-Frame-Options "SAMEORIGIN"
        # Prevent MIME-type sniffing
        X-Content-Type-Options "nosniff"
        # Enable XSS protection
        X-XSS-Protection "1; mode=block"
        # Referrer policy
        Referrer-Policy "strict-origin-when-cross-origin"
        # Remove server information
        -Server
    }

    # Access logging
    log {
        output stdout
        format console
    }
}

# -----------------------------------------------------------------------------
# PRODUCTION CONFIGURATION - vogalingo.win
# -----------------------------------------------------------------------------
# Due to firewall issues, using HTTP-only for now
# SSL will be enabled once firewall is properly configured
# 
# Access via: http://vogalingo.win:8080 or http://localhost:8080

vogalingo.win:8080 {
    # Reverse proxy to the mission-control Next.js application
    # WebSocket support is automatic with Caddy's reverse_proxy
    reverse_proxy mission-control:3000

    # Enable compression for better performance
    encode gzip zstd

    # Security headers
    header {
        # Prevent clickjacking attacks
        X-Frame-Options "SAMEORIGIN"
        # Prevent MIME-type sniffing
        X-Content-Type-Options "nosniff"
        # Enable XSS protection in browsers
        X-XSS-Protection "1; mode=block"
        # Control referrer information
        Referrer-Policy "strict-origin-when-cross-origin"
        # Remove server information for security
        -Server
    }

    # Access logging
    log {
        output stdout
        format json
    }
}

# Redirect www to non-www
www.vogalingo.win:8080 {
    redir http://vogalingo.win:8080{uri} permanent
}

# -----------------------------------------------------------------------------
# ADDITIONAL NOTES
# -----------------------------------------------------------------------------
# - Caddy automatically provisions and renews TLS certificates via Let's Encrypt
# - For production, ensure your domain's DNS is properly configured
# - The mission-control hostname resolves via Docker's internal network
# - Adjust Content-Security-Policy based on your application's needs
